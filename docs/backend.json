
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a citizen's basic health profile and authentication linkage.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity, corresponding to the Firebase Authentication UID."
        },
        "name": {
          "type": "string",
          "description": "The full name of the user."
        },
        "phone": {
          "type": "string",
          "description": "The user's contact phone number."
        },
        "age": {
          "type": "number",
          "description": "The user's age in years."
        },
        "gender": {
          "type": "string",
          "description": "The user's self-declared gender (e.g., 'Male', 'Female', 'Other', 'Prefer not to say')."
        },
        "preferredLanguage": {
          "type": "string",
          "description": "The user's preferred language for application interface and communications (e.g., 'en', 'hi')."
        },
        "city": {
          "type": "string",
          "description": "The user's current city of residence."
        },
        "emergencyContactName": {
          "type": "string",
          "description": "The name of the user's emergency contact person."
        },
        "emergencyContactPhone": {
          "type": "string",
          "description": "The phone number of the user's emergency contact."
        },
        "abhaId": {
          "type": "string",
          "description": "The user's Ayushman Bharat Health Account (ABHA) ID, if available. This field is optional."
        },
        "bloodGroup": {
          "type": "string",
          "description": "Blood group of the user."
        },
        "allergies": {
          "type": "string",
          "description": "Known allergies."
        },
        "medications": {
          "type": "string",
          "description": "Currently prescribed medications."
        },
        "pastSurgeries": {
          "type": "string",
          "description": "History of surgeries."
        },
        "existingDiseases": {
          "type": "string",
          "description": "Chronic conditions like Diabetes, Hypertension."
        },
        "vaccinationNotes": {
          "type": "string",
          "description": "Notes on vaccinations."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user profile was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the user profile was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "phone",
        "age",
        "gender",
        "preferredLanguage",
        "city",
        "emergencyContactName",
        "emergencyContactPhone",
        "createdAt",
        "updatedAt"
      ]
    },
    "DoctorProfile": {
      "type": "object",
      "description": "Public clinical profile for medical professionals available for discovery.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "clinicName": { "type": "string" },
        "city": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "experienceYears": { "type": "number" },
        "rating": { "type": "number" },
        "availability": { "type": "string" },
        "consultationFee": { "type": "number" },
        "verified": { "type": "boolean" }
      },
      "required": ["id", "name", "specialization", "clinicName"]
    },
    "ChatTriageRecord": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "symptoms": { "type": "string" },
        "duration": { "type": "string" },
        "painScore": { "type": "number" },
        "redFlags": { "type": "array", "items": { "type": "string" } },
        "severity": { "type": "string" },
        "explanation": { "type": "string" },
        "recommendation": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "const": "chatbot" }
      },
      "required": ["id", "userId", "severity", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          }
        }
      },
      {
        "path": "/doctors/{doctorId}",
        "definition": {
          "entityName": "DoctorProfile",
          "schema": {
            "$ref": "#/backend/entities/DoctorProfile"
          }
        }
      },
      {
        "path": "/chat_triage_records/{recordId}",
        "definition": {
          "entityName": "ChatTriageRecord",
          "schema": {
            "$ref": "#/backend/entities/ChatTriageRecord"
          }
        }
      }
    ]
  }
}
