rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isHardcodedAdmin() {
      return isSignedIn() && request.auth.uid == "Zn1wDP2cfzNglUFfGyVQAi64qSk2";
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == 'admin';
    }

    function isDoctor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == 'doctor';
    }

    function isVerifiedDoctor() {
      return isDoctor() && 
             getUserData().verificationStatus == 'verified';
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Allow individual read for self, or admin/doctor clinical lookup
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isHardcodedAdmin() || isVerifiedDoctor());
      
      // Allow listing for search purposes only for staff
      allow list: if isSignedIn() && (isAdmin() || isHardcodedAdmin() || isVerifiedDoctor());
      
      // Self-creation
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // Update by self or admin (admin needed for verification/role assignment)
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isHardcodedAdmin());
      
      allow delete: if isOwner(userId);

      // Sub-collections for health records
      match /triageAssessments/{triageId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      match /doctorSummaries/{summaryId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      match /preventiveAssessments/{assessmentId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    match /doctorApplications/{appId} {
      // Admin can see all applications, doctors can see their own status
      allow read, list: if isAdmin() || isHardcodedAdmin() || (isSignedIn() && appId == request.auth.uid);
      
      // Doctors create their own applications
      allow create: if isSignedIn() && appId == request.auth.uid;
      
      // Only admins can process applications (update/delete)
      allow update, delete: if isAdmin() || isHardcodedAdmin();
    }

    match /consultationChats/{chatId} {
      // Access allowed if the user's UID is part of the chatId (sorted combo of IDs)
      allow read, write: if isSignedIn() && (chatId.contains(request.auth.uid));
      
      match /messages/{msgId} {
        allow read, write: if isSignedIn() && (chatId.contains(request.auth.uid));
      }
    }

    match /sos_alerts/{alertId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /medical_imaging_reports/{reportId} {
      // Access for owner, verified doctor for review, or admin
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isVerifiedDoctor() || isAdmin() || isHardcodedAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isVerifiedDoctor() || isAdmin() || isHardcodedAdmin());
    }

    match /chat_triage_records/{recordId} {
       allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || isHardcodedAdmin());
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}