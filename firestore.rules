rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isDoctor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    function isVerifiedDoctor() {
      return isDoctor() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.verificationStatus == 'verified';
    }

    match /users/{userId} {
      // Allow individual read or admin/doctor search
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isVerifiedDoctor());
      // Allow listing for search purposes
      allow list: if isSignedIn() && (isAdmin() || isVerifiedDoctor());
      
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // Admin can update any user (for verification), owner can update self
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      allow delete: if isOwner(userId);

      match /triageAssessments/{triageId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /doctorSummaries/{summaryId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /preventiveAssessments/{assessmentId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    match /doctorApplications/{appId} {
      // Admin can see all, doctor can see own
      allow read, list: if isAdmin() || (isSignedIn() && appId == request.auth.uid);
      allow create: if isSignedIn() && appId == request.auth.uid;
      // Only admin can approve/reject
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /consultationChats/{chatId} {
      allow read, write: if isSignedIn() && (chatId.contains(request.auth.uid));
      
      match /messages/{msgId} {
        allow read, write: if isSignedIn() && (get(/databases/$(database)/documents/consultationChats/$(chatId)).data.chatId.contains(request.auth.uid));
      }
    }

    match /sos_alerts/{alertId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /medical_imaging_reports/{reportId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isVerifiedDoctor() || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isVerifiedDoctor() || isAdmin());
    }
  }
}