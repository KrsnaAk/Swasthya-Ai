
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isHardcodedAdmin() {
      return isSignedIn() && request.auth.uid == "Zn1wDP2cfzNglUFfGyVQAi64qSk2";
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == 'admin';
    }

    function isDoctor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == 'doctor';
    }

    function isVerifiedDoctor() {
      return isDoctor() && 
             getUserData().verificationStatus == 'verified';
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isHardcodedAdmin() || isVerifiedDoctor());
      allow list: if isSignedIn() && (isAdmin() || isHardcodedAdmin() || isVerifiedDoctor());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isHardcodedAdmin());
      allow delete: if isOwner(userId);

      match /triageAssessments/{triageId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      match /doctorSummaries/{summaryId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      match /preventiveAssessments/{assessmentId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    // Public clinical discovery for patients
    match /doctors/{doctorId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isHardcodedAdmin();
    }

    match /doctorApplications/{appId} {
      allow read, list: if isHardcodedAdmin() || isAdmin() || (isSignedIn() && appId == request.auth.uid);
      allow create: if isSignedIn() && appId == request.auth.uid;
      allow update, delete: if isHardcodedAdmin() || isAdmin();
    }

    // --- Consultation Chat Rules (Hackathon Demo Mode) ---
    match /consultationChats/{chatId} {
      allow read, create, update: if isSignedIn();
      
      match /messages/{messageId} {
        allow read, list, create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    match /sos_alerts/{alertId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /medical_imaging_reports/{reportId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isVerifiedDoctor() || isAdmin() || isHardcodedAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isVerifiedDoctor() || isAdmin() || isHardcodedAdmin());
    }

    match /chat_triage_records/{recordId} {
       allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || isHardcodedAdmin());
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /preConsultations/{consultationId} {
      allow create: if isSignedIn();
      allow get, list: if isSignedIn() && (
        isAdmin() || 
        isHardcodedAdmin() || 
        isVerifiedDoctor() || 
        resource.data.userId == request.auth.uid || 
        resource.data.patientId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        isAdmin() || 
        isHardcodedAdmin() || 
        isVerifiedDoctor() || 
        resource.data.userId == request.auth.uid || 
        resource.data.patientId == request.auth.uid || 
        resource.data.doctorId == request.auth.uid
      );
      allow delete: if isHardcodedAdmin() || isAdmin();
    }
  }
}
